# Sleeper league id (the long number in your league URL on sleeper.app)
VITE_SLEEPER_LEAGUE_ID=1245387983213821952

# Optional: hide the “All nominations” table on /keepers until this instant (ISO 8601). Leave unset to always show.
# VITE_KEEPERS_REVEAL_AT=2026-08-20T12:00:00-04:00

# Postgres connection string (TCP). Local: postgresql://user:pass@localhost:5432/dbname
# (same DB you use in pgAdmin). On Vercel + Neon, use the connection string from the Neon dashboard.
DATABASE_URL=

# Optional: one shared password for the whole site. When set together with AUTH_SECRET (16+ chars),
# visitors must sign in; session is an HttpOnly cookie. Leave blank to keep the app open.
SITE_PASSWORD=admin
AUTH_SECRET=1234567890123456
